# ====================
# OpenAI / LLM API (DashScope compatible)
# ====================
# API 密钥（兼容 OpenAI 格式）
OPENAI_API_KEY=sk-3e63c7503caa429181765da416b2309b
# API 基础地址（阿里云 DashScope）
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# 默认 LLM 模型
LLM_DEFAULT_MODEL=qwen-flash
# 默认温度参数
LLM_DEFAULT_TEMPERATURE=0.1

# VLM视觉语言模型
VL_MODEL=qwen3-vl-flash
# 商品名识别相关模型
ITEM_MODEL=qwen-flash
# 知识图谱模型
KG_MODEL=qwen-flash

# ====================
# BGE Embedding Models
# ====================
# BGE-M3 模型本地路径
BGE_M3_PATH=D:\ai_models\modelscope_cache\models\BAAI\bge-m3
# 嵌入模型运行设备
BGE_DEVICE=cuda:0
# 是否使用半精度
BGE_FP16=True
# BGE 重排序模型路径
BGE_RERANKER_LARGE=D:\ai_models\modelscope_cache\models\BAAI\BAAI\bge-reranker-large
# 重排序模型设备
BGE_RERANKER_DEVICE=cuda:0
# 重排序模型半精度
BGE_RERANKER_FP16=1
# 项目名称诊断标志
ITEM_NAME_DIAG=1

# ====================
# Embedding General
# ====================
# 嵌入向量维度
EMBEDDING_DIM=1536
# 嵌入模型名称
EMBEDDING_MODEL=text-embedding-v4

# ====================
# Vector Database (Milvus)
# ====================
# Milvus 连接地址
MILVUS_URL=http://192.168.200.130:19530
# 知识库集合名
CHUNKS_COLLECTION=kb_chunks_v1


# 商品名称集合名
ITEM_NAME_COLLECTION=kb_item_names_v1

# 相似度度量方式
MILVUS_METRIC_TYPE=COSINE
# 最小余弦相似度阈值
MILVUS_MIN_COSINE_SCORE=0.75



# ====================
# Document Database (MongoDB)
# ====================
# MongoDB 连接 URL
MONGO_URL=mongodb://admin:123456@192.168.200.130:27017
# 数据库名
MONGO_DB_NAME=kb001

# ====================
# Object Storage (MinIO)
# ====================
# MinIO 服务端点
MINIO_ENDPOINT=192.168.200.145:9000
# 访问密钥
MINIO_ACCESS_KEY=minioadmin
# 私有密钥
MINIO_SECRET_KEY=minioadmin
# 存储桶名称

MINIO_BUCKET_NAME=knowledge-base-v1

# ====================
# Other / MCP Services
# ====================
# MCP Web 搜索服务地址
MCP_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/mcp